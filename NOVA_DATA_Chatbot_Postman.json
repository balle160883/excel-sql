{
    "info": {
        "_postman_id": "chatbot-categorized-collection",
        "name": "Nova Data - Chatbot por Categorías",
        "description": "Colección organizada por áreas funcionales para el chatbot con los nombres REALES de las tablas del Excel.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "— UTILIDADES —",
            "item": [
                {
                    "name": "Buscar en Utilidades",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "X-API-Key",
                                "value": "{{chatbot_api_key}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"table\": \"descripciones_tablas\",\n    \"message\": \"{{search_term}}\",\n    \"limit\": 5\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/chatbot/search",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "chatbot",
                                "search"
                            ]
                        }
